      "@/components/ui/select": ["./src/components/select/select.tsx"],
      "@/components/ui/separator": ["./src/components/separator/separator.tsx"],
      "@/components/ui/table": ["./src/components/table/table.tsx"],
      "@/components/ui/toggle": ["./src/components/toggle/toggle.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "test", "tsup.config.ts", "vitest.config.ts"]
