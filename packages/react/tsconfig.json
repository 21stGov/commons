    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/components/ui/button": ["./src/components/button/button.tsx"],
      "@/components/ui/calendar": ["./src/components/calendar/calendar.tsx"],
      "@/components/ui/checkbox": ["./src/components/checkbox/checkbox.tsx"],
      "@/components/ui/collapsible": ["./src/components/collapsible/collapsible.tsx"],
      "@/components/ui/combo-box": ["./src/components/combo-box/combo-box.tsx"],
      "@/components/ui/context": ["./src/components/field/context.ts"],
      "@/components/ui/dialog": ["./src/components/dialog/dialog.tsx"],
      "@/components/ui/drawer": ["./src/components/drawer/drawer.tsx"],
      "@/components/ui/dropdown-menu": ["./src/components/dropdown-menu/dropdown-menu.tsx"],
      "@/components/ui/field": ["./src/components/field/field.tsx"],
      "@/components/ui/icon": ["./src/components/icon/icon.tsx"],
