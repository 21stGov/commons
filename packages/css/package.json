{
  "name": "@21stgov/commons-css",
  "version": "0.5.0",
  "type": "module",
  "license": "MIT",
  "description": "Framework-agnostic component CSS for Commons — use the components in any stack (Drupal, WordPress, plain HTML), no React or Tailwind build required.",
  "homepage": "https://commonsui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/21stGov/commons.git",
    "directory": "packages/css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/*.css"
  ],
  "exports": {
    ".": "./dist/commons.css",
    "./commons.css": "./dist/commons.css",
    "./components.css": "./dist/components.src.css"
  },
  "scripts": {
    "build": "tsx build.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@21stgov/commons-react": "workspace:*",
    "@21stgov/commons-tokens": "workspace:*",
    "@tailwindcss/cli": "^4.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "node-html-parser": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.0",
    "typescript": "~5.9.0",
    "vitest": "^4.1.10"
  }
}
