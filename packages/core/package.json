{
  "name": "@21stgov/commons-core",
  "version": "0.4.0",
  "description": "Framework-agnostic CSS foundation for the Commons design system — accessible reset, base styles, and a11y utilities.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "homepage": "https://commonsui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/21stGov/commons.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    "./index.css": "./dist/index.css",
    "./css/*": "./dist/*"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "pnpm run build",
    "lint": "stylelint \"src/**/*.css\""
  },
  "peerDependencies": {
    "@21stgov/commons-tokens": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@21stgov/commons-tokens": {
      "optional": true
    }
  },
  "devDependencies": {
    "lightningcss": "1.32.0",
    "stylelint": "17.14.0",
    "stylelint-plugin-logical-css": "2.1.0"
  },
  "keywords": [
    "design-system",
    "accessibility",
    "wcag",
    "css",
    "government",
    "21stgov",
    "commons"
  ]
}
