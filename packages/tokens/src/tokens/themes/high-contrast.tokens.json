{
  "text": {
    "$type": "color",
    "$description": "High-contrast theme (a first-class theme, not a hack): every text/bg pairing >= 7:1, borders on everything, extra-prominent focus ring.",
    "default": {
      "$value": "{color.black}"
    },
    "muted": {
      "$value": "{color.gray.80}"
    },
    "on-emphasis": {
      "$value": "{color.white}"
    }
  },
  "link": {
    "$type": "color",
    "default": {
      "$value": "{color.blue.70}"
    },
    "visited": {
      "$value": "{color.violet.70}"
    },
    "hover": {
      "$value": "{color.blue.80}"
    }
  },
  "bg": {
    "$type": "color",
    "default": {
      "$value": "{color.white}"
    },
    "subtle": {
      "$value": "{color.gray.5}"
    },
    "emphasis": {
      "$value": "{color.black}"
    }
  },
  "border": {
    "$type": "color",
    "default": {
      "$value": "{color.black}"
    },
    "strong": {
      "$value": "{color.black}"
    }
  },
  "focus": {
    "ring": {
      "$type": "color",
      "$value": "{color.blue.40}"
    },
    "width": {
      "$type": "dimension",
      "$value": "0.375rem"
    },
    "offset": {
      "$type": "dimension",
      "$value": "0.125rem"
    }
  },
  "state": {
    "$type": "color",
    "info": {
      "bg": {
        "$value": "{color.cyan.5}"
      },
      "text": {
        "$value": "{color.cyan.80}"
      },
      "border": {
        "$value": "{color.cyan.80}"
      }
    },
    "warning": {
      "bg": {
        "$value": "{color.gold.5}"
      },
      "text": {
        "$value": "{color.gold.80}"
      },
      "border": {
        "$value": "{color.gold.80}"
      }
    },
    "error": {
      "bg": {
        "$value": "{color.red.5}"
      },
      "text": {
        "$value": "{color.red.80}"
      },
      "border": {
        "$value": "{color.red.80}"
      }
    },
    "success": {
      "bg": {
        "$value": "{color.green.5}"
      },
      "text": {
        "$value": "{color.green.80}"
      },
      "border": {
        "$value": "{color.green.80}"
      }
    },
    "emergency": {
      "bg": {
        "$value": "{color.red.80}"
      },
      "text": {
        "$value": "{color.white}"
      },
      "border": {
        "$value": "{color.red.30}"
      }
    }
  },
  "disabled": {
    "$type": "color",
    "text": {
      "$value": "{color.gray.70}"
    },
    "bg": {
      "$value": "{color.gray.5}"
    },
    "border": {
      "$value": "{color.gray.70}"
    }
  },
  "action": {
    "$type": "color",
    "$description": "High-contrast action tokens: every text/fill pairing >= 7:1.",
    "primary": {
      "bg": {
        "$value": "{color.blue.80}"
      },
      "text": {
        "$value": "{color.white}"
      },
      "hover": {
        "$value": "{color.blue.90}"
      },
      "active": {
        "$value": "{color.blue.90}"
      }
    },
    "secondary": {
      "bg": {
        "$value": "{color.gray.5}"
      },
      "text": {
        "$value": "{color.gray.90}"
      },
      "hover": {
        "$value": "{color.gray.10}"
      },
      "active": {
        "$value": "{color.gray.20}"
      }
    },
    "danger": {
      "bg": {
        "$value": "{color.red.80}"
      },
      "text": {
        "$value": "{color.white}"
      },
      "hover": {
        "$value": "{color.red.90}"
      },
      "active": {
        "$value": "{color.red.90}"
      }
    }
  }
}
