{
  "motion": {
    "duration": {
      "$description": "Animation durations. Components must respect prefers-reduced-motion by dropping to duration.instant.",
      "$type": "duration",
      "instant": { "$value": "0ms" },
      "fast": { "$value": "150ms" },
      "base": { "$value": "250ms" },
      "slow": { "$value": "400ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0, 0, 1] },
      "enter": { "$value": [0, 0, 0.2, 1] },
      "exit": { "$value": [0.4, 0, 1, 1] },
      "linear": { "$value": [0, 0, 1, 1] }
    }
  }
}
