{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "registry#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/packages/react/src/**",
        "$TURBO_ROOT$/apps/html-playground/src/generated/demos/**"
      ]
    },
    "playground#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/react/src/**"]
    },
    "docs#build": {
      "dependsOn": [
        "registry#build",
        "@21stgov/commons-tokens#build",
        "@21stgov/commons-core#build",
        "@21stgov/commons-css#build",
        "@21stgov/commons-js#build",
        "^build"
      ],
      "outputs": ["out/**", ".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/react/src/**"]
    },
    "docs#typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/react/src/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
