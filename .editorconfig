# SPDX-License-Identifier: MIT
# Commons code style: 2-space indent, single quotes, no semicolons (see .prettierrc)
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
