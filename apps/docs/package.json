{
  "name": "docs",
  "version": "0.0.2",
  "description": "commonsui.com — homepage, documentation, and static registry for Commons.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsx scripts/generate.ts && next build && tsx scripts/postbuild.ts",
    "typecheck": "tsx scripts/generate.ts --content-only && fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@21stgov/commons-core": "workspace:*",
    "@21stgov/commons-fonts": "workspace:*",
    "@21stgov/commons-react": "workspace:*",
    "@21stgov/commons-tokens": "workspace:*",
    "@orama/orama": "^3.1.11",
    "fumadocs-core": "^16.11.3",
    "fumadocs-mdx": "^15.1.0",
    "fumadocs-ui": "^16.11.3",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
