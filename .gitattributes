# Normalize line endings: LF in the repository for all text files.
* text=auto eol=lf

# Windows scripts keep CRLF so they run when checked out.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.tar binary
*.gz binary
*.mp4 binary
*.webm binary
*.pdf binary
